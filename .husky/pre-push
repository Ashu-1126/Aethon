echo "Checking for merge commits before push..."

MERGE_COMMITS=$(git log main..HEAD --merges --oneline 2>/dev/null)
if [ -n "$MERGE_COMMITS" ]; then
  echo "❌ Error: Merge commits are not allowed."
  echo "Please use 'git pull --rebase origin main' instead of git merge."
  echo "Merge commits found:"
  echo "$MERGE_COMMITS"
  exit 1
fi

echo "✅ Pre-push check passed."
