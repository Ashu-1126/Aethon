# AETHON Frontend — copy to .env.local and adjust as needed
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_ALLOW_DEMO_LOGIN=false

# true = use lib/mock.ts (no backend needed) · false = call the real backend
NEXT_PUBLIC_USE_MOCK=false

# Authentication Secrets
JWT_SECRET_KEY=your-secure-jwt-secret-key
ADMIN_PASSWORD=admin-password-here
AUDITOR_PASSWORD=auditor-password-here
ENGINEER_PASSWORD=engineer-password-here

# ==========================================
# Backend & Orchestration Variables (for docker-compose)
# ==========================================
# LLM Endpoint
OLLAMA_URL=http://ollama:11434

# Vector Store Endpoint
CHROMA_URL=http://chromadb:8000
